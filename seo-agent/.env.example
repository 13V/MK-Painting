# Google Search Console — service account credentials (JSON string)
# Either set this variable OR place a credentials.json file in seo-agent/
GSC_CREDENTIALS_JSON=

# Anthropic API key for Claude-powered recommendations
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Telegram Bot — for daily report notifications and PR approval
# Create a bot via @BotFather, then message it to get your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
